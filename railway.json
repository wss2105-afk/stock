{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "pip install gunicorn && python -m gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --timeout 120",
    "sleepApplication": false,
    "multiRegionConfig": {
      "asia-northeast3-an3a1a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
